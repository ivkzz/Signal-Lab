# =============================================================================
# Docker Compose подставляет значения из этого файла (копия: `.env` в корне).
# Команда: `docker compose up -d` — читает `.env` автоматически из каталога compose.
# =============================================================================

# --- Порты (хост:контейнер) ---
# FRONTEND_PORT — только проброс Next на хост (в контейнере приложение слушает :3000).
FRONTEND_PORT=3000
# Backend API + /metrics на хосте; NEXT_PUBLIC_* ниже подставляют ${PORT}.
PORT=3001
# PostgreSQL на хосте; DATABASE_URL для инструментов с хоста подставляет ${POSTGRES_PORT}.
POSTGRES_PORT=5432
# Prometheus UI на хосте; NEXT_PUBLIC_PROMETHEUS_URL подставляет ${PROMETHEUS_PORT}.
PROMETHEUS_PORT=9090
# Loki с хоста (не совпадает с GRAFANA_PORT: оба нельзя вешать на один порт).
# Проверка готовности с хоста: `http://localhost:<LOKI_HOST_PORT>/ready` (по умолчанию порт 3101).
LOKI_HOST_PORT=3101
# Grafana UI на хосте (PRD: порт 3100).
GRAFANA_PORT=3100

# --- Node / окружение приложений ---
NODE_ENV=production

# --- Next.js — только UI Signal Lab (`loadEnvConfig` в apps/frontend/next.config.ts) ---
# В Docker те же ключи подставляет compose в сервис `frontend`.
# ${PORT}, ${PROMETHEUS_PORT}, ${GRAFANA_PORT} раскрываются и в Compose, и в Next (dotenv-expand в @next/env).
NEXT_PUBLIC_API_URL=http://localhost:${PORT}/api
NEXT_PUBLIC_GRAFANA_URL=http://localhost:${GRAFANA_PORT}
NEXT_PUBLIC_PROMETHEUS_URL=http://localhost:${PROMETHEUS_PORT}
NEXT_PUBLIC_BACKEND_METRICS_URL=http://localhost:${PORT}/metrics

# --- Grafana — только контейнер `grafana` (официальные GF_* из docker-compose) ---
# Next их не использует. Нужны самой Grafana: редиректы, ссылки в UI, логин admin.
GF_SERVER_ROOT_URL=http://localhost:${GRAFANA_PORT}/
GF_SERVER_SERVE_FROM_SUB_PATH=false
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false

# --- PostgreSQL ---
DATABASE_URL=postgresql://postgres:postgres@localhost:${POSTGRES_PORT}/signal_lab?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=signal_lab

# --- Observability (backend) ---
# Внутри Docker-сети (не localhost хоста).
LOKI_URL=http://loki:3101
PROMETHEUS_URL=http://prometheus:9090
# Пусто = Sentry отключён локально; для PRD walkthrough (system_error в Sentry) задайте DSN проекта.
SENTRY_DSN=
