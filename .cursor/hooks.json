{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/signal-lab-after-file-edit.cjs",
        "timeout": 15
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/signal-lab-before-git-commit.cjs",
        "matcher": "git\\s+commit|git\\.exe\\s+commit",
        "timeout": 30
      }
    ]
  }
}
