{
  "hooks": [
    {
      "name": "prisma-schema-guard",
      "event": "afterEdit",
      "include": [
        "prisma/schema.prisma"
      ],
      "action": {
        "type": "prompt",
        "message": "Schema обновлена: запусти Prisma migration/generate flow и проверь компиляцию backend."
      }
    },
    {
      "name": "backend-observability-reminder",
      "event": "afterEdit",
      "include": [
        "apps/backend/src/**/*.ts"
      ],
      "action": {
        "type": "prompt",
        "message": "Backend code изменен: проверь coverage для metrics/log/Sentry и сохрани валидность `/metrics` + dashboard queries."
      }
    },
    {
      "name": "pre-commit-secrets-check",
      "event": "beforeCommit",
      "action": {
        "type": "command",
        "command": "rg -n --hidden --glob \"!.git\" --glob \"!.next\" \"(SENTRY_DSN=.+|DATABASE_URL=.+|API_KEY=.+|SECRET=.+)\" .env*"
      }
    }
  ]
}
