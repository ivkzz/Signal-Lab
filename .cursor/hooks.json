{
  "version": 1,
  "hooks": {
    "preCompact": [
      {
        "command": "bash .cursor/hooks/signal-lab-pre-compact.sh",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash .cursor/hooks/signal-lab-after-file-edit.sh",
        "timeout": 15
      }
    ],
    "beforeShellExecution": [
      {
        "command": "bash .cursor/hooks/signal-lab-before-git-commit.sh",
        "matcher": "git\\s+commit|git\\.exe\\s+commit",
        "timeout": 30
      },
      {
        "command": "bash .cursor/hooks/signal-lab-before-destructive-shell.sh",
        "matcher": "(npx\\s+|pnpm\\s+exec\\s+|yarn\\s+)?prisma(\\.exe)?\\s+(migrate\\s+reset|db\\s+push|db\\s+execute)\\b",
        "timeout": 15
      },
      {
        "command": "bash .cursor/hooks/signal-lab-before-destructive-shell.sh",
        "matcher": "docker-compose.*\\bdown\\b.*(-v\\b|--volumes\\b)|docker(\\.exe)?\\s+compose.*\\bdown\\b.*(-v\\b|--volumes\\b)",
        "timeout": 15
      }
    ]
  }
}
